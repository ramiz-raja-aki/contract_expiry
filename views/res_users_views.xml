<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add Contract Expiry Notification field to the User form (Preferences tab) -->
    <record id="view_users_form_contract_expiry_notification" model="ir.ui.view">
        <field name="name">res.users.form.contract.expiry.notification</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='preferences']" position="inside">
                <group string="Contract Expiry Notifications">
                    <field name="id_expire_notification"
                           widget="boolean_toggle"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
